# Resend — https://resend.com/api-keys
# Required for the contact form to send email.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Where contact-form submissions are delivered.
CONTACT_TO_EMAIL=you@example.com

# Optional: the "from" address. Until you verify your own domain in Resend,
# leave this unset and the app uses Resend's shared testing sender.
# Once your domain is verified, set e.g.:
# RESEND_FROM=Kinsey Lawrence <hello@yourdomain.com>
# RESEND_FROM=
